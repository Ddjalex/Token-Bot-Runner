modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MySQL Server"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/artifacts/telegram-bot/start-bot.sh"
waitForPort = 3001

[[workflows.workflow]]
name = "MySQL Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/artifacts/telegram-bot/start-mysql.sh"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
BOT_TOKEN = "8427577528:AAF3z-O84R-oRALh5hiEJnUJWu5x5M-EnP0"
WEBAPP_URL = "https://test-frontend.chapabingo.com"
API_BASE_URL = "https://api.chapabingo.com"
JWT_SECRET = "adfac"
JWT_EXPIRES_IN = "7d"
NODE_ENV = "development"
DB_HOST = "127.0.0.1"
DB_PORT = "3306"
DB_USER = "root"
DB_PASSWORD = ""
DB_NAME = "bingo_db"

[nix]
channel = "stable-25_05"
packages = ["mysql80"]
